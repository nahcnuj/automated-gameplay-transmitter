{
  "name": "automated-gameplay-transmitter",
  "version": "0.3.0",
  "type": "module",
  "exports": {
    ".": {
      "source": "./index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/index.node.js",
      "types": "./dist/index.node.d.ts"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nahcnuj/automated-gameplay-transmitter"
  },
  "scripts": {
    "dev": "bun --hot --port=7777 bin/server.ts",
    "start": "NODE_ENV=production bun --port=7777 bin/server.ts",
    "build": "bun run build.ts",
    "build:lib": "bun run build.ts --lib && tsc --project tsconfig.lib.json",
    "prepublishOnly": "bun run build:lib"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "dependencies": {
    "@playwright/browser-chromium": "^1.57.0",
    "bun-plugin-tailwind": "^0.1.2",
    "playwright": "^1.57.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.3",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/node": "^24.10.7",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.2"
  }
}
