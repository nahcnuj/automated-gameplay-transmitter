{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationDir": "./dist"
  },
  "include": ["index.ts", "index.node.ts", "index.agent.ts", "src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["dist", "node_modules", "src/**/*.test.ts", "src/**/*.test.tsx", "bin", "build.ts"]
}
